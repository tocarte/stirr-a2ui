{
  "$schema": "https://a2ui.org/specification/v0_8/standard_catalog_definition.json",
  "version": "v0.8",
  "catalogId": "stirr-intent",
  "description": "STIRR intent-aware catalog: content discovery + Weather, Traffic, Finance widgets",
  "components": {
    "ContentShelf": {
      "description": "Horizontal shelf of content cards for STIRR",
      "extends": ["List"],
      "properties": {
        "title": { "type": "string", "description": "Shelf title" }
      }
    },
    "ConversationalSearch": {
      "description": "Search input + results list for STIRR content discovery",
      "extends": ["Column"],
      "properties": {
        "placeholder": { "type": "string", "description": "Search input placeholder" }
      }
    },
    "NewsAlertBanner": {
      "description": "Breaking-news banner. Card + Text + optional Icon.",
      "extends": ["Card"],
      "properties": {
        "headline": { "type": "string", "description": "Alert headline" },
        "summary": { "type": "string", "description": "Brief summary" },
        "iconName": { "type": "string", "description": "Optional icon (e.g. alert, info)" }
      }
    },
    "ScoreOverlay": {
      "description": "Score display overlay for sports. Card + Text + Row layout.",
      "extends": ["Card"],
      "properties": {
        "homeTeam": { "type": "string", "description": "Home team name" },
        "awayTeam": { "type": "string", "description": "Away team name" },
        "homeScore": { "type": "integer", "description": "Home team score" },
        "awayScore": { "type": "integer", "description": "Away team score" },
        "period": { "type": "string", "description": "e.g. Q3, 2nd Half, Final" }
      }
    },
    "ChapterNav": {
      "description": "Chapter list for long-form content. List + Button per chapter, action for seek.",
      "extends": ["List"],
      "properties": {
        "chapters": { "type": "array", "description": "Array of {title, timestamp, action}" },
        "currentChapter": { "type": "string", "description": "ID of current chapter" }
      }
    },
    "VideoPlayer": {
      "description": "Video playback. Renders play_url (watch page iframe) or hls_url (HLS manifest) when available.",
      "extends": ["Card"],
      "properties": {
        "play_url": { "type": "string", "description": "Watch page URL or fallback (e.g. https://stirr.com/watch/{id})" },
        "hls_url": { "type": "string", "description": "Direct HLS manifest (.m3u8) when available (DataGraphs streamUrl, live epg_url)" },
        "title": { "type": "string", "description": "Video title" },
        "isLive": { "type": "boolean", "description": "True for live streams" }
      }
    },
    "WeatherWidget": {
      "description": "P4-H15a: Intent-aware weather widget for KNOW/DO moments. Location-based weather card.",
      "extends": ["Card"],
      "properties": {
        "location": { "type": "string", "description": "City/region (e.g. Albany, NY)" },
        "temp_f": { "type": "number", "description": "Temperature in Fahrenheit" },
        "condition": { "type": "string", "description": "Weather condition (e.g. Partly Cloudy)" },
        "forecast": { "type": "string", "description": "7-day or short forecast text" },
        "humidity": { "type": "string", "description": "Humidity" },
        "alerts": { "type": "array", "items": { "type": "string" }, "description": "Weather alerts" },
        "summary": { "type": "string", "description": "Brief summary" }
      }
    },
    "TrafficWidget": {
      "description": "P4-H15a: Intent-aware traffic widget for KNOW/GO moments. Road conditions, delays, accidents.",
      "extends": ["Card"],
      "properties": {
        "location": { "type": "string", "description": "City/region" },
        "conditions": { "type": "string", "description": "Road conditions summary" },
        "delays": { "type": "array", "items": { "type": "string" }, "description": "Delay descriptions" },
        "accidents": { "type": "array", "items": { "type": "string" }, "description": "Accident reports" },
        "summary": { "type": "string", "description": "Brief summary" }
      }
    },
    "FinanceWidget": {
      "description": "P4-H15a: Intent-aware finance widget for KNOW/DO moments. Stock ticker, price, change.",
      "extends": ["Card"],
      "properties": {
        "symbol": { "type": "string", "description": "Stock symbol (e.g. AAPL)" },
        "name": { "type": "string", "description": "Company name" },
        "price": { "type": "number", "description": "Current price" },
        "change": { "type": "number", "description": "Price change" },
        "change_pct": { "type": "string", "description": "Percent change" },
        "summary": { "type": "string", "description": "Brief summary" }
      }
    }
  }
}
